# ====================================================================
# 星瀚空间网站 - 环境变量配置示例
# --------------------------------------------------------------------
# 使用方法：
#   1. 复制本文件为 .env （或直接在系统环境中设置同名变量）
#   2. 根据部署环境修改下面各项值
#   3. 启动后端：python server.py（会自动读取这些环境变量）
# ====================================================================

# ---- Flask 应用 ----
# 绑定地址，默认 0.0.0.0
HOST=0.0.0.0
# 端口，默认 5000
PORT=5000
# 调试模式：生产环境务必为 false
DEBUG=false

# ---- 安全密钥 ----
# 用于 session 签名等；生产环境请设置为一段足够长的随机字符串。
# 可用 python -c "import secrets;print(secrets.token_hex(32))" 生成
SECRET_KEY=please-change-me-to-a-long-random-string

# ---- 跨域 (CORS) ----
# 允许访问后端 API 的前端来源，多个用英文逗号分隔
ALLOWED_ORIGINS=https://www.your-domain.com,https://your-domain.com

# ---- HTTPS ----
# 生产环境（已部署 SSL/TLS）请设为 true，强制 HTTPS 跳转与 HSTS
FORCE_HTTPS=true

# ---- 速率限制存储 ----
# 本地开发或单进程可不设（默认 memory://）；
# 多 worker / 生产环境推荐使用 Redis：
# REDIS_URL=redis://127.0.0.1:6379/0
REDIS_URL=memory://
